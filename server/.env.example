# BirdWatch Server Environment Variables
# Copy this file to .env and fill in ALL values

# =============================================================================
# Server Configuration (ALL REQUIRED)
# =============================================================================

# Session secret - use a random 32+ character string
# Generate with: openssl rand -base64 32
BIRDWATCH_SESSION_SECRET=

# Shared secret for Pi authentication
# Generate with: openssl rand -base64 24
BIRDWATCH_PI_SECRET=

# Stream key for RTMP authentication
# Generate with: openssl rand -base64 24
BIRDWATCH_STREAM_KEY=

# Path to file containing allowed email addresses (one per line)
# Relative to working directory
BIRDWATCH_ALLOWED_EMAILS_FILE=allowed_emails.csv

# Directory for HLS segments
BIRDWATCH_HLS_DIR=/tmp/hls

# HLS segment duration in seconds
BIRDWATCH_HLS_SEGMENT_DURATION=4

# Number of HLS segments to keep in playlist
BIRDWATCH_HLS_LIST_SIZE=10

# RTMP server port
BIRDWATCH_RTMP_PORT=1935

# HTTP server port
BIRDWATCH_PORT=8080

# Base URL for external links (protocol + hostname, no trailing slash)
# Used in notifications and other external-facing URLs
BIRDWATCH_BASE_URL=https://example.com

# Base path for all routes
BIRDWATCH_BASE_PATH=/birdwatch

# Path to Google OAuth JSON credentials file
# Relative to working directory
BIRDWATCH_GOOGLE_AUTH_FILE=google_auth.json

# Directory for persistent data (SQLite database and sighting images)
BIRDWATCH_DATA_DIR=./data

# =============================================================================
# Pushover Notification Configuration (OPTIONAL)
#   If either variable is not set, notifications will not be enabled
# =============================================================================

# Pushover API Token
# Get from https://pushover.net/apps/build
BIRDWATCH_PUSHOVER_API_TOKEN=

# Pushover User Key (who to send notifications to)
# Get from https://pushover.net/
BIRDWATCH_PUSHOVER_USER_KEY=

# Pushover Admin User Key (for admin-only notifications like login attempts)
# Get from https://pushover.net/
BIRDWATCH_PUSHOVER_ADMIN_USER_KEY=

# =============================================================================
# Stream Downtime Configuration (OPTIONAL)
#   Set both to disable streaming during a daily time window
#   If neither is set, streaming is available 24/7
#   Supports overnight ranges (e.g. 23:00 - 06:00)
# =============================================================================

# Downtime start time in 24h format (HH:MM)
BIRDWATCH_STREAM_DOWNTIME_START=

# Downtime end time in 24h format (HH:MM)
BIRDWATCH_STREAM_DOWNTIME_END=

# Timezone for downtime window (IANA format, e.g. America/New_York). Defaults to UTC.
BIRDWATCH_STREAM_DOWNTIME_TIMEZONE=
