# BirdWatch Raspberry Pi Environment Variables
# Copy this file to .env and fill in ALL values - no defaults are provided

# =============================================================================
# Raspberry Pi Configuration (ALL REQUIRED)
# =============================================================================

# Server URL for status polling
BIRDWATCH_SERVER_URL=https://example.com

# RTMP URL for streaming
BIRDWATCH_RTMP_URL=rtmp://example.com:1935

# Shared secret for Pi authentication (must match server)
# Generate with: openssl rand -base64 24
BIRDWATCH_PI_SECRET=

# Stream key for RTMP authentication (must match server)
# Generate with: openssl rand -base64 24
BIRDWATCH_STREAM_KEY=

# Poll interval in seconds
BIRDWATCH_POLL_INTERVAL=5

# Stream settings
BIRDWATCH_STREAM_WIDTH=1280
BIRDWATCH_STREAM_HEIGHT=720
BIRDWATCH_STREAM_FRAMERATE=30
BIRDWATCH_STREAM_BITRATE=2M # in bits. Also supports 'K' and 'M' suffixes

# =============================================================================
# Motion Detection Configuration (OPTIONAL)
# =============================================================================

# Enable motion detection (default: true)
BIRDWATCH_MOTION_DETECTION_ENABLED=true

# Frames per second to check for motion (default: 10)
BIRDWATCH_MOTION_DETECTION_FPS=10

# Motion sensitivity threshold (default: 25, lower = more sensitive)
BIRDWATCH_MOTION_THRESHOLD=25

# Minimum area of motion to trigger detection (default: 10000 pixels)
BIRDWATCH_MOTION_MIN_AREA=10000

# Cooldown between detection events in seconds (default: 20)
BIRDWATCH_MOTION_COOLDOWN=20

# Delay, in seconds, before capturing screenshot after motion is detected (default: 2)
BIRDWATCH_MOTION_CAPTURE_DELAY=2

# Number of images to capture per sighting (default: 3)
BIRDWATCH_MOTION_CAPTURE_COUNT=3

# Interval in seconds between captures (default: 1)
BIRDWATCH_MOTION_CAPTURE_INTERVAL=1

# How many frames the motion detector algorithm (MOG2) uses (default: 200)
BIRDWATCH_MOTION_HISTORY=200

# =============================================================================
# Camera Focus Configuration (OPTIONAL - Camera Module 3 only)
# =============================================================================

# Enable autofocus (default: true). Set to false for manual focus.
BIRDWATCH_CAMERA_AUTOFOCUS=true

# Manual focus position in dioptres (only used when autofocus is false)
# 0.0 = infinity, 0.5 = 2m, 1.0 = 1m, 2.0 = 0.5m, 10.0 = 10cm
BIRDWATCH_CAMERA_FOCUS_POSITION=
