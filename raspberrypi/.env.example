# BirdWatch Raspberry Pi Environment Variables
# Copy this file to .env and fill in ALL values - no defaults are provided

# =============================================================================
# Raspberry Pi Configuration (ALL REQUIRED)
# =============================================================================

# Server URL for status polling
BIRDWATCH_SERVER_URL=https://example.com

# RTMP URL for streaming
BIRDWATCH_RTMP_URL=rtmp://example.com:1935

# Shared secret for Pi authentication (must match server)
# Generate with: openssl rand -base64 24
BIRDWATCH_PI_SECRET=

# Stream key for RTMP authentication (must match server)
# Generate with: openssl rand -base64 24
BIRDWATCH_STREAM_KEY=

# Poll interval in seconds
BIRDWATCH_POLL_INTERVAL=5

# Stream settings
BIRDWATCH_STREAM_WIDTH=1280
BIRDWATCH_STREAM_HEIGHT=720
BIRDWATCH_STREAM_FRAMERATE=30
BIRDWATCH_STREAM_BITRATE=2M # in bits. Also supports 'K' and 'M' suffixes
